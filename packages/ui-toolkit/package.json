{
  "name": "@jellyfin-vue/ui-toolkit",
  "description": "Base components and UI toolkit for Jellyfin Vue",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    "./composables/*.ts": "./src/composables/*.ts",
    "./components": "./src/components/index.ts",
    "./store": "./src/store/index.ts",
    "./resolver": "./src/resolver.ts"
  },
  "scripts": {
    "check:types": "vue-tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:inspect": "eslint-config-inspector",
    "storybook": "storybook dev -p 6006 --config-dir storybook --no-open"
  },
  "dependencies": {
    "@jellyfin-vue/i18n": "workspace:*",
    "@jellyfin-vue/shared": "workspace:*",
    "@skirtle/vue-vnode-utils": "0.2.0",
    "@vueuse/core": "catalog:",
    "color": "5.0.3",
    "comlink": "catalog:",
    "i18next-vue": "catalog:",
    "vuetify": "catalog:"
  },
  "devDependencies": {
    "@jellyfin-vue/configs": "workspace:*",
    "unplugin-vue-components": "catalog:"
  }
}
